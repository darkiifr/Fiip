<form @submit.prevent="buyNow">
  <div class="row mb-2">
    {% if product.variants.length > 1 %}
      <div class="mb-3 col-12">
        <label for="method" class="form-label">Variant</label>
        <div class="d-flex flex-wrap variants">
          {% for variant in product.variants %}
            <button
              type="button"
              class="variant btn-primary"
              :class="`${activeVariant == {{ loop.index0 }} ? 'active' : ''}`"
              @click="() => activeVariant = {{ loop.index0 }}"
              {{ 'title="Out of Stock"' if variant.stock === 0 }}
              {{ 'disabled' if variant.stock === 0 }}
            >
              <div class="name-stock">
                <p class="name">{{ variant.name }}</p>
                {% if variant.description %}
                  <p class="description text-muted">{{ variant.description }}</p>
                {% endif %}
                <p class="stock text-muted">
                  {% if variant.stock === 0 %}
                    <span>Out of Stock</span>
                  {% elif product.hide_stock_count %}
                    <span>In Stock</span>
                  {% elif variant.stock === -1 %}
                    <span class="stock-unlimited">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 256 256"><path d="M248,128a56,56,0,0,1-95.6,39.6l-.33-.35L92.12,99.55a40,40,0,1,0,0,56.9l8.52-9.62a8,8,0,1,1,12,10.61l-8.69,9.81-.33.35a56,56,0,1,1,0-79.2l.33.35,59.95,67.7a40,40,0,1,0,0-56.9l-8.52,9.62a8,8,0,1,1-12-10.61l8.69-9.81.33-.35A56,56,0,0,1,248,128Z"></path></svg>
                      In Stock
                    </span>
                  {% else %}
                    <span>{{ variant.stock }} In Stock</span>
                  {% endif %}
                </p>
              </div>
              <div class="price">
                <span x-text="appCurrency.format({{ variant.price }}, '{{ product.currency }}')">
                  {{ formatPrice(variant.price, product.currency) }}
                </span>
                {% if variant.price_slash %}
                  <s class="opacity-50">
                    <span x-text="appCurrency.format({{ variant.price_slash }}, '{{ product.currency }}')">
                      {{ formatPrice(variant.price_slash, product.currency) }}
                    </span>
                  </s>
                {% endif %}
              </div>
              <template x-if="activeVariant == {{ loop.index0 }}">
                <div class="active-indicator">
                  <svg
                    class="text-primary"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </div>
              </template>
            </button>
          {% endfor %}
        </div>
        <small
          x-show="!(activeVariant in product.variants)"
          x-cloak
          class="form-text text-danger"
        >
          Please select a variant.
        </small>
      </div>
    {% endif %}

    <div class="mb-3 col-12">
      <label for="quantity" class="form-label">Quantity</label>
      <div class="input-group col-4">
        <button
          @click="changeQuantity(quantity - 1)"
          type="button"
          class="btn btn-outline-primary input-group-btn"
          :disabled="outOfStock || quantity <= minQuantity"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 12h-15"
            />
          </svg>
        </button>
        <input
          type="number"
          class="form-control"
          name="quantity"
          x-model.number="quantity"
          :min="minQuantity"
          :max="maxQuantity"
          :disabled="outOfStock"
        />
        <button
          @click="changeQuantity(quantity + 1)"
          type="button"
          class="btn btn-outline-primary input-group-btn"
          :disabled="outOfStock || quantity >= maxQuantity"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 4.5v15m7.5-7.5h-15"
            />
          </svg>
        </button>
      </div>

      <small
        x-show="!outOfStock && (quantity < minQuantity || quantity > maxQuantity)"
        x-cloak
        class="form-text text-danger"
      >
        Please enter a valid quantity (from <span x-text="minQuantity"></span> to <span x-text="maxQuantity"></span>).
      </small>

      <div x-show="availableVolumeDiscount">
        <div class="form-control text-center mt-2">
          Buy <span x-text="availableVolumeDiscount?.quantity - quantity"></span> more to get a <span x-text="availableVolumeDiscount?.percentage"></span>% discount.
        </div>
      </div>
    </div>

    {% if productAddons and productAddons.length > 0 %}
      <div class="mb-3 col-12">
        <label class="form-label">Addons</label>
        <div class="d-flex flex-column gap-2">
          {% for addon in productAddons %}
            <div class="addon-item d-flex align-items-center justify-content-between gap-3 p-3 rounded">
              <div class="d-flex align-items-center gap-2 flex-grow-1">
                {% if addon.image_urls and addon.image_urls[0] %}
                  <img 
                    src="{{ addon.image_urls[0] }}" 
                    alt="{{ addon.name }}"
                    class="addon-image rounded"
                  >
                {% endif %}
                <div class="flex-grow-1">
                  <p class="mb-1 fw-medium">{{ addon.name }}</p>
                  {% if addon.description %}
                    <p class="mb-1 small text-muted" style="white-space: pre-line;">{{ addon.description }}</p>
                  {% endif %}
                </div>
              </div>
              <div class="d-flex align-items-center gap-3">
                <span class="fw-medium" x-text="appCurrency.format('{{ addon.variants[0].price }}', '{{ addon.currency }}')">
                  {{ formatPrice(addon.variants[0].price, addon.currency) }}
                </span>
                <button
                  type="button"
                  x-show="!appCart.isInCart({{ addon.variants[0].id }}, variant.id)"
                  x-on:click="appCart.add({{ addon.id }}, {{ addon.variants[0].id }}, 1, variant.id)"
                  class="btn btn-sm btn-addon-add d-flex justify-content-center align-items-center gap-1"
                  :disabled="outOfStock || product.visibility == 'on_hold' || cartLimitReached || addingToCart"
                >
                  <span>Add</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M11 13H6q-.425 0-.712-.288T5 12t.288-.712T6 11h5V6q0-.425.288-.712T12 5t.713.288T13 6v5h5q.425 0 .713.288T19 12t-.288.713T18 13h-5v5q0 .425-.288.713T12 19t-.712-.288T11 18z"/></svg>
                </button>
                {% if addon.is_mandatory %}
                  <button
                    type="button"
                    x-show="appCart.isInCart({{ addon.variants[0].id }}, variant.id)"
                    class="btn btn-sm btn-addon-add d-flex justify-content-center align-items-center gap-1"
                    disabled
                    title="This addon is mandatory"
                  >
                    <span>Added</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="m9.55 15.15l8.475-8.475q.3-.3.7-.3t.7.3t.3.713t-.3.712l-9.175 9.2q-.3.3-.7.3t-.7-.3L4.55 13q-.3-.3-.288-.712t.313-.713t.713-.3t.712.3z"/></svg>
                  </button>
                {% else %}
                  <button
                    type="button"
                    x-show="appCart.isInCart({{ addon.variants[0].id }}, variant.id)"
                    x-on:click="appCart.remove({{ addon.variants[0].id }}, variant.id)"
                    class="btn btn-sm btn-addon-remove d-flex justify-content-center align-items-center gap-1"
                    :disabled="outOfStock || product.visibility == 'on_hold' || cartLimitReached || addingToCart"
                  >
                    <span>Remove</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="m12 13.4l-4.9 4.9q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7l4.9-4.9l-4.9-4.9q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.9 4.9l4.9-4.9q.275-.275.7-.275t.7.275t.275.7t-.275.7L13.4 12l4.9 4.9q.275.275.275.7t-.275.7t-.7.275t-.7-.275z"/></svg>
                  </button>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% if altcha and not properties.hide_buy_now %}
      <div
        x-cloak
        x-show="!altchaPayload"
        class="transition-opacity"
        x-transition:enter="transition ease-out duration-300 transform"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-200 transform"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
      >
        <altcha-widget
          challengejson='{{ altcha | json }}'
          auto="onload"
          hidefooter="true"
          hidelogo="true"
          x-ref="altcha"
        ></altcha-widget>
      </div>
    {% endif %}

    <div
      x-cloak
      x-show="buyNowError"
      class="transition-opacity"
      x-transition:enter="transition ease-out duration-300 transform"
      x-transition:enter-start="opacity-0" 
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition ease-in duration-200 transform"
      x-transition:leave-start="opacity-100" 
      x-transition:leave-end="opacity-0"
    >
      <div
        class="alert alert-warning"
        role="alert"
        x-text="buyNowError"
      ></div>
    </div>
    
    <div class="fiip-legal-consent mt-3">
      <p>
        En continuant l'achat, vous acceptez les
        <a href="{{ '/terms-of-service' | shopUrl }}" target="_blank" rel="noopener">Conditions generales d'utilisation</a>,
        la <a href="{{ '/privacy-policy' | shopUrl }}" target="_blank" rel="noopener">Politique de confidentialite</a>
        et la <a href="{{ '/refund-policy' | shopUrl }}" target="_blank" rel="noopener">Politique de remboursement</a>.
        Les licences Fiip sont des produits numeriques livres automatiquement ; aucun remboursement n'est accepte apres livraison et/ou activation de la cle, sauf garantie legale applicable.
      </p>
    </div>

    <div class="d-flex flex flex-column flex-lg-row mt-4 gap-3 buy-buttons">
      {% if not properties.hide_add_to_cart %}
      <div class="col">
        <button
          type="button"
          x-on:click="addToCart"
          class="w-100 btn btn-primary"
          :disabled="outOfStock || product.visibility == 'on_hold' || cartLimitReached || addingToCart"
        >
          <template x-if="!addingToCart && !addedToCart">
            <span class="d-flex align-items-center justify-content-center gap-2">
              <span x-text="cartLimitReached ? 'Cart Limit Reached' : 'Add to Cart'"></span>
              <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="currentColor" viewBox="0 0 256 256"><path d="M230.14,58.87A8,8,0,0,0,224,56H62.68L56.6,22.57A8,8,0,0,0,48.73,16H24a8,8,0,0,0,0,16h18L67.56,172.29a24,24,0,0,0,5.33,11.27,28,28,0,1,0,44.4,8.44h45.42A27.75,27.75,0,0,0,160,204a28,28,0,1,0,28-28H91.17a8,8,0,0,1-7.87-6.57L80.13,152h116a24,24,0,0,0,23.61-19.71l12.16-66.86A8,8,0,0,0,230.14,58.87ZM104,204a12,12,0,1,1-12-12A12,12,0,0,1,104,204Zm96,0a12,12,0,1,1-12-12A12,12,0,0,1,200,204Zm4-74.57A8,8,0,0,1,196.1,136H77.22L65.59,72H214.41Z"></path></svg>
            </span>
          </template>
          <template x-if="addingToCart">
            <span class="d-flex align-items-center justify-content-center gap-2">
              <span>Adding...&nbsp;&nbsp;</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="size-5 animate-spin" fill="currentColor" viewBox="0 0 256 256"><path d="M232,128a104,104,0,0,1-208,0c0-41,23.81-78.36,60.66-95.27a8,8,0,0,1,6.68,14.54C60.15,61.59,40,93.27,40,128a88,88,0,0,0,176,0c0-34.73-20.15-66.41-51.34-80.73a8,8,0,0,1,6.68-14.54C208.19,49.64,232,87,232,128Z"></path></svg>
            </span>
          </template>
          <template x-if="addedToCart">
            <span class="d-flex align-items-center justify-content-center gap-2">
              <span>Go to Cart</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="currentColor" viewBox="0 0 256 256"><path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"></path></svg>
            </span>
          </template>
        </button>
      </div>
      {% endif %}
      {% if not properties.hide_buy_now %}
        <div class="col">
          <button
            type="submit"
            class="w-100 btn btn-outline-primary"
            :disabled="outOfStock || product.visibility == 'on_hold' || buyingNow || buyNowDisabled"
          >
            <span>Buy Now</span>
            <template x-if="!buyingNow">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="currentColor" viewBox="0 0 256 256"><path d="M237.66,122.34l-96-96A8,8,0,0,0,128,32V72H104a8,8,0,0,0-8,8v96a8,8,0,0,0,8,8h24v40a8,8,0,0,0,13.66,5.66l96-96A8,8,0,0,0,237.66,122.34ZM144,204.69V176a8,8,0,0,0-8-8H112V88h24a8,8,0,0,0,8-8V51.31L220.69,128ZM48,80v96a8,8,0,0,1-16,0V80a8,8,0,0,1,16,0Zm32,0v96a8,8,0,0,1-16,0V80a8,8,0,0,1,16,0Z"></path></svg>
            </template>
            <template x-if="buyingNow">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-5 animate-spin" fill="currentColor" viewBox="0 0 256 256"><path d="M232,128a104,104,0,0,1-208,0c0-41,23.81-78.36,60.66-95.27a8,8,0,0,1,6.68,14.54C60.15,61.59,40,93.27,40,128a88,88,0,0,0,176,0c0-34.73-20.15-66.41-51.34-80.73a8,8,0,0,1,6.68-14.54C208.19,49.64,232,87,232,128Z"></path></svg>
            </template>
          </button>
        </div>
      {% endif %}
    </div>
  </div>
</form>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('productForm', () => ({
      product: {{ product | json }},
      productAddons: {{ productAddons | json }},
      activeVariant: 0,
      quantity: {{ product.quantity_min or 1 }},
      isEmbed: {{ 'true' if is_embed else 'false' }},
      addingToCart: false,
      addedToCart: false,
      buyingNow: false,
      buyNowError: null,
      buyNowDisabled: false,
      altchaPayload: null,

      get variant() {
        return this.product.variants[this.activeVariant];
      },

      init: function () {
        const urlParams = new URLSearchParams(window.location.search);

        // Prefill variant from URL parameter if present.
        if (urlParams.has('variant')) {
          const variantIndex = this.product.variants.findIndex(variant => variant.name === urlParams.get('variant'));
          if (variantIndex !== -1) {
            this.activeVariant = variantIndex;
          }
        } else {
          // Choose the first variant that has stock.
          for (let i = 0; i < this.product.variants.length; i++) {
            if (this.product.variants[i].stock !== 0) {
              this.activeVariant = i;
              break;
            }
          }
        }

        if (this.variant.quantity_min) {
          this.quantity = this.variant.quantity_min;
        }

        if (urlParams.has('quantity')) {
          const urlQuantity = parseInt(urlParams.get('quantity'));
          if (!isNaN(urlQuantity) && urlQuantity >= this.minQuantity && urlQuantity <= this.maxQuantity) {
            this.quantity = urlQuantity;
          }
        }

        this.$watch('activeVariant', () => {
          this.quantity = this.product.quantity_min || 1;

          if (this.variant.quantity_min) {
            this.quantity = this.variant.quantity_min;
          }

          this.addedToCart = false;

          // Add mandatory addons.
          for (const addon of this.productAddons) {
            if (addon.is_mandatory) {
              if (!this.appCart.isInCart(addon.variants[0].id, this.variant.id)) {
                this.appCart.add(addon.id, addon.variants[0].id, 1, this.variant.id);
              }
            }
          }
        });

        this.$watch('quantity', () => {
          this.addedToCart = false;
        });

        {% if altcha and not properties.hide_buy_now %}
          this.addAltchaEventListener();
        {% endif %}
      },

      get availableVolumeDiscount() {
        if (this.variant.volume_discounts) {
          const volumeDiscounts = [...this.variant.volume_discounts].sort((a, b) => a.quantity - b.quantity);

          for (const volumeDiscount of volumeDiscounts) {
            if (this.quantity < parseInt(volumeDiscount.quantity)) {
              return volumeDiscount;
            }
          }
        }

        return null;
      },

      get totalPrice() {
        let price = this.variant.price * this.quantity;
        let priceBeforeDiscounts = price;

        // Apply volume discounts
        if (this.variant.volume_discounts) {
          const volumeDiscounts = [...this.variant.volume_discounts].sort((a, b) => a.quantity - b.quantity);

          for (const volumeDiscount of volumeDiscounts) {
            if (this.quantity >= parseInt(volumeDiscount.quantity)) {
              price = price - (priceBeforeDiscounts * parseInt(volumeDiscount.percentage) / 100);
              break;
            }
          }
        }

        // Append prices of addons
        if (this.appCart.items.length > 0) {
          for (const item of this.appCart.items) {
            if (item.parentVariantId === this.variant.id) {
              const addonVariant = this.productAddons.find(addon => addon.id === item.productId && addon.variants.some(variant => variant.id === item.variantId));
              if (addonVariant) {
                const addonPrice = addonVariant.variants.find(variant => variant.id === item.variantId).price;
                price += addonPrice * item.quantity;
              }
            }
          }
        }

        // If price is negative, set it to 0
        if (price < 0) {
          price = 0;
        }

        // Format the price to have 2 decimal places
        const formattedPrice = price.toFixed(2);

        return formattedPrice;
      },

      get outOfStock() {
        if (this.variant) {
          if (this.variant.stock === 0) {
            return true;
          }

          if (this.variant.quantity_min > 0 && this.variant.stock !== -1 && !this.product.hide_stock_count && this.variant.stock < this.variant.quantity_min) {
            return true;
          }
        }

        return false;
      },

      get minQuantity() {
        const min = this.variant.quantity_min || 1;

        if (this.variant.stock === 0) {
          return 0;
        }

        return min;
      },

      get maxQuantity() {
        const max = this.variant.quantity_max || 999999;

        if (this.variant.stock === 0) {
          return 0;
        }

        if (this.product.hide_stock_count) {
          return max;
        }

        if (this.variant.stock === -1) {
          return max;
        }

        return Math.min(max, this.variant.stock);
      },

      changeQuantity: function (quantity) {
        const min = this.minQuantity;
        const max = this.maxQuantity;
        const newQuantity = Math.min(Math.max(min, quantity), max);

        this.quantity = newQuantity;
      },

      get cartLimitReached() {
        const nonAddonItemsCount = this.appCart.items
          .filter(item => !item.parentVariantId)
          .length;

        return nonAddonItemsCount >= {{ shop.max_cart_limit }};
      },

      addToCart: function () {
        if (this.addedToCart) {
          window.location.href = '{{ '/cart' | shopUrl }}';
          return;
        }

        this.addingToCart = true;

        const productId = this.product.id;
        const variantId = this.variant.id;
        const quantity = this.quantity;

        this.appCart.add(productId, variantId, quantity);

        setTimeout(() => {
          this.addedToCart = true;
          this.addingToCart = false;
        }, 1000);
      },

      addAltchaEventListener: function () {
        this.$refs.altcha.addEventListener('statechange', (event) => {
          if (event.detail.state === 'verifying') {
            this.buyNowDisabled = true;
          } else if (event.detail.state === 'verified') {
            this.buyNowDisabled = false;
            this.altchaPayload = event.detail.payload;
          }
        });
      },

      buyNow: async function () {
        if (this.buyingNow) {
          return;
        }

        if (this.quantity < this.minQuantity || this.quantity > this.maxQuantity) {
          this.buyNowError = `Please enter a valid quantity (from ${this.minQuantity} to ${this.maxQuantity}).`;
          return;
        }

        const buyNowCart = [{
          productId: this.product.id,
          variantId: this.variant.id,
          quantity: this.quantity,
        }];

        if (this.appCart.items.length > 0) {
          for (const item of this.appCart.items) {
            if (item.parentVariantId === this.variant.id) {
              buyNowCart.push({
                productId: item.productId,
                variantId: item.variantId,
                parentVariantId: item.parentVariantId,
                quantity: item.quantity,
              });
            }
          }
        }

        const formData = {
          cart: buyNowCart,
          currency: this.appCurrency.currency,
          shopId: '{{ shop.id }}',
        };

        if (window.shopCustomer?.email) {
          formData.email = window.shopCustomer.email;
        }

        {% if altcha %}
          if (this.altchaPayload) {
            formData.altcha = this.altchaPayload;
          }
        {% endif %}

        try {
          this.buyingNow = true;

          const response = await fetch('{{ '/v1/checkout' | apiInternalUrl }}', {
            method: 'POST',
            headers: {
              'Accept': 'application/json',
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(formData),
          });

          const responseData = await response.json();

          if (responseData.url) {
            this.checkoutUrl = responseData.url;

            // Open in new tab if we're in an embed.
            if (this.isEmbed) {
              window.open(this.checkoutUrl, '_blank');
            } else {
              window.location.href = this.checkoutUrl;
            }
          } else {
            this.buyingNow = false;
            this.buyNowError = responseData?.message || 'Error in the AJAX request.';
          }
        } catch (error) {
          console.error(error);
          this.buyingNow = false;
          this.buyNowError = 'Unexpected error. Please refresh the page and try again.';
        }
      }
    }));
  });
</script>

