{% set title_to_use = properties.default_title %}
{% if category and properties.category_title %}
  {% set title_to_use = properties.category_title %}
{% endif %}

<div class="container component" data-component-id="{{ componentId }}">
  <section
    class="py-5-nav"
    x-data="{
      submitForm() {
        const form = event.target;
        const inputs = form.querySelectorAll('input, select, textarea');
        inputs.forEach(input => {
          if (!input.value) {
            input.disabled = true;
          }
        });
        form.submit();
      }
    }"
  >
    {% if title_to_use %}
      <div class="section-title">
        <h1>{{ title_to_use | renderString }}</h1>
      </div>
    {% endif %}

    <div class="d-lg-none mb-4">
      <button
        type="button"
        data-bs-toggle="modal"
        data-bs-target="#filters-modal"
        class="btn btn-primary w-100 d-flex align-items-center justify-content-center gap-2"
      >
        <span>Filters</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><path fill="currentColor" d="M11 20q-.425 0-.712-.288T10 19v-6L4.2 5.6q-.375-.5-.112-1.05T5 4h14q.65 0 .913.55T19.8 5.6L14 13v6q0 .425-.288.713T13 20z"/></svg>
      </button>
    </div>

    <div class="row">
      <aside class="col-lg-3 d-none d-lg-block mb-4">
        <div class="bg-gray rounded p-4">
          <form x-on:submit.prevent="submitForm">
            <div class="mb-4">
              <label class="form-label fw-bold">Categories</label>
              <div class="d-flex flex-column gap-1">
                <a
                  href="{{ '/products' | shopUrl }}"
                  class="btn btn-sm text-start {% if not category %}btn-primary{% else %}btn-outline{% endif %}"
                >
                  All Categories
                </a>
                {% for cat in category_links %}
                  <a
                    href="{{ cat.url }}"
                    class="btn btn-sm text-start {% if category and category.id == cat.id %}btn-primary{% else %}btn-outline{% endif %}"
                    style="padding-left: {{ (cat.depth * 12 + 12) }}px"
                  >
                    {{ cat.name }}
                  </a>
                {% endfor %}
              </div>
            </div>
            <div class="mb-4">
              <label for="filters[keyword]" class="form-label fw-bold">Keyword</label>
              <input
                type="text"
                name="filters[keyword]"
                id="filters[keyword]"
                value="{{ filters.keyword }}"
                placeholder="Search..."
                class="form-control"
              />
            </div>
            <div class="mb-4">
              <label class="form-label fw-bold">Price Range</label>
              <input type="hidden" name="filters[price][currency]" :value="appCurrency.currency" />
              <div class="row g-2">
                <div class="col-6">
                  <div class="position-relative">
                    <input
                      type="number"
                      name="filters[price][from]"
                      min="0"
                      value="{{ filters.price.from }}"
                      placeholder="Min"
                      class="form-control pe-5"
                    />
                    <span class="position-absolute top-50 end-0 translate-middle-y pe-3 text-muted small">
                      <span x-text="window.currencySymbols[appCurrency.currency.toLowerCase()]"></span>
                    </span>
                  </div>
                </div>
                <div class="col-6">
                  <div class="position-relative">
                    <input
                      type="number"
                      name="filters[price][to]"
                      min="0"
                      value="{{ filters.price.to }}"
                      placeholder="Max"
                      class="form-control pe-5"
                    />
                    <span class="position-absolute top-50 end-0 translate-middle-y pe-3 text-muted small">
                      <span x-text="window.currencySymbols[appCurrency.currency.toLowerCase()]"></span>
                    </span>
                  </div>
                </div>
              </div>
            </div>
            <div class="d-flex flex-column gap-2">
              <button
                type="submit"
                class="w-100 btn btn-primary"
              >
                <span>Apply</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><path fill="currentColor" d="M16.15 13H5q-.425 0-.712-.288T4 12t.288-.712T5 11h11.15L13.3 8.15q-.3-.3-.288-.7t.288-.7q.3-.3.713-.312t.712.287L19.3 11.3q.15.15.213.325t.062.375t-.062.375t-.213.325l-4.575 4.575q-.3.3-.712.288t-.713-.313q-.275-.3-.288-.7t.288-.7z"/></svg>
              </button>
              <a
                href="{{ '/products' | shopUrl }}"
                class="w-100 btn btn-outline-primary"
              >
                <span>Reset</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><path fill="currentColor" d="M12 22q-1.875 0-3.512-.712t-2.85-1.925t-1.925-2.85T3 13h2q0 2.925 2.038 4.963T12 20t4.963-2.037T19 13t-2.037-4.962T12 6h-.15l1.55 1.55L12 9L8 5l4-4l1.4 1.45L11.85 4H12q1.875 0 3.513.713t2.85 1.925t1.925 2.85T21 13t-.712 3.513t-1.925 2.85t-2.85 1.925T12 22"/></svg>
              </a>
            </div>
          </form>
        </div>
      </aside>
      <div class="col-lg-9">
        {% if items.length > 0 %}
          <div class="row products">
            {% for item in items %}
              {% if item.type == 'group' or not item.group_id %}
                <div class="col-12 col-md-6 col-lg-4 mb-4">
                  {% render_snippet "product-card.njk", product=item %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% else %}
          <div class="text-center py-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="mb-3 text-muted" width="96" height="96" viewBox="0 0 24 24"><path fill="currentColor" d="M11 18q-.425 0-.712-.288T10 17t.288-.712T11 16h2q.425 0 .713.288T14 17t-.288.713T13 18zm-4-5q-.425 0-.712-.288T6 12t.288-.712T7 11h10q.425 0 .713.288T18 12t-.288.713T17 13zM4 8q-.425 0-.712-.288T3 7t.288-.712T4 6h16q.425 0 .713.288T21 7t-.288.713T20 8z"/></svg>
            <p class="text-muted fs-5">
              No products found matching your criteria.
            </p>
          </div>
        {% endif %}

        {% if items_paginator.last_page > 1 %}
          <div class="mt-4">
            {% render_snippet "pagination.njk", paginator=items_paginator %}
          </div>
        {% endif %}
      </div>
    </div>
  </section>

  <div class="modal fade" id="filters-modal" tabindex="-1" aria-labelledby="filters-modal-label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Filters</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <form x-on:submit.prevent="submitForm">
            <div class="mb-4">
              <label class="form-label fw-bold">Categories</label>
              <div class="d-flex flex-column gap-1">
                <a
                  href="{{ '/products' | shopUrl }}"
                  class="btn btn-sm text-start {% if not category %}btn-primary{% else %}btn-outline{% endif %}"
                >
                  All Categories
                </a>
                {% for cat in category_links %}
                  <a
                    href="{{ cat.url }}"
                    class="btn btn-sm text-start {% if category and category.id == cat.id %}btn-primary{% else %}btn-outline{% endif %}"
                    style="padding-left: {{ (cat.depth * 12 + 12) }}px"
                  >
                    {{ cat.name }}
                  </a>
                {% endfor %}
              </div>
            </div>
            <div class="mb-4">
              <label for="filters-mobile[keyword]" class="form-label fw-bold">Keyword</label>
              <input
                type="text"
                name="filters[keyword]"
                id="filters-mobile[keyword]"
                value="{{ filters.keyword }}"
                placeholder="Search..."
                class="form-control"
              />
            </div>
            <div class="mb-4">
              <label class="form-label fw-bold">Price Range</label>
              <input type="hidden" name="filters[price][currency]" :value="appCurrency.currency" />
              <div class="row g-2">
                <div class="col-6">
                  <div class="position-relative">
                    <input
                      type="number"
                      name="filters[price][from]"
                      min="0"
                      value="{{ filters.price.from }}"
                      placeholder="Min"
                      class="form-control pe-5"
                    />
                    <span class="position-absolute top-50 end-0 translate-middle-y pe-3 text-muted small">
                      <span x-text="window.currencySymbols[appCurrency.currency.toLowerCase()]"></span>
                    </span>
                  </div>
                </div>
                <div class="col-6">
                  <div class="position-relative">
                    <input
                      type="number"
                      name="filters[price][to]"
                      min="0"
                      value="{{ filters.price.to }}"
                      placeholder="Max"
                      class="form-control pe-5"
                    />
                    <span class="position-absolute top-50 end-0 translate-middle-y pe-3 text-muted small">
                      <span x-text="window.currencySymbols[appCurrency.currency.toLowerCase()]"></span>
                    </span>
                  </div>
                </div>
              </div>
            </div>
            <div class="d-flex flex-column gap-2">
              <button
                type="submit"
                class="w-100 btn btn-primary"
              >
                <span>Apply</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><path fill="currentColor" d="M16.15 13H5q-.425 0-.712-.288T4 12t.288-.712T5 11h11.15L13.3 8.15q-.3-.3-.288-.7t.288-.7q.3-.3.713-.312t.712.287L19.3 11.3q.15.15.213.325t.062.375t-.062.375t-.213.325l-4.575 4.575q-.3.3-.712.288t-.713-.313q-.275-.3-.288-.7t.288-.7z"/></svg>
              </button>
              <a
                href="{{ '/products' | shopUrl }}"
                class="w-100 btn btn-outline-primary"
              >
                <span>Reset</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><path fill="currentColor" d="M12 22q-1.875 0-3.512-.712t-2.85-1.925t-1.925-2.85T3 13h2q0 2.925 2.038 4.963T12 20t4.963-2.037T19 13t-2.037-4.962T12 6h-.15l1.55 1.55L12 9L8 5l4-4l1.4 1.45L11.85 4H12q1.875 0 3.513.713t2.85 1.925t1.925 2.85T21 13t-.712 3.513t-1.925 2.85t-2.85 1.925T12 22"/></svg>
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  {% for item in items %}
    {% if item.type == 'group' %}
      <div class="modal fade" id="group-modal-{{ item.id }}" tabindex="-1" aria-labelledby="group-modal-{{ item.id }}-label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-xl">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="group-modal-{{ item.id }}-label">
                {{ item.name }} Products
              </h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <div class="products row">
                {% for product in item.products %}
                  <div class="col-12 col-md-6 col-lg-4 col-xl-3 mb-4">
                    {% render_snippet "product-card.njk", product=product %}
                  </div>
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endif %}
  {% endfor %}
</div>