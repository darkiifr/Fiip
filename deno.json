{
  "name": "fiip",
  "version": "9.0.4",
  "exports": "./src/main.jsx",
  "nodeModulesDir": "manual",

  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["dom", "dom.iterable", "dom.asynciterable", "deno.ns"]
  },
  "tasks": {
    "dev": "deno run -A npm:vite",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "lint": "deno run -A npm:eslint .",
    "tauri": "deno run -A npm:@tauri-apps/cli",
    "test": "npm run test",
    "test:all": "npm run test:all",
    "test:extensions": "npm run test:extensions",
    "test:coverage": "npm run test:coverage",
    "test:watch": "npm run test:watch",
    "security-check": "npm audit --audit-level=moderate",
    "security-check:all": "npm run security-check:all",
    "package:extensions": "node scripts/package-browser-extensions.mjs",
    "security-fix": "npm audit fix",
    "security-fix:all": "npm run security-fix:all",
    "quality": "deno task lint && deno task test && deno task build && deno task security-check",
    "quality:all": "deno task lint && deno task test:all && deno task build && deno task security-check:all",
    "build:update": "deno run -A scripts/bump-version.mjs && deno run -A npm:dotenv-cli -e .env -- deno task tauri build && deno run -A scripts/generate-latest.mjs"
  },
