  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "postinstall": "patch-package",
    "lint": "eslint .",
    "tauri": "tauri",
    "test": "vitest run --pool=forks --maxWorkers=1 --no-file-parallelism",
    "test:all": "npm run test && npm --prefix PublicLinksite test && npm --prefix Mobile test -- --runInBand",
    "test:extensions": "vitest run BrowserExtension/content-helpers.test.js BrowserExtension/background-helpers.test.js BrowserExtension/popup-helpers.test.js BrowserExtension/manifest.test.js scripts/package-browser-extensions.test.js scripts/publish-chrome-extension.test.js",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "security-check": "npm audit --audit-level=moderate",
    "security-check:all": "npm audit --audit-level=moderate && npm --prefix PublicLinksite audit --audit-level=moderate && npm --prefix Mobile audit --audit-level=moderate",
    "package:extensions": "node scripts/package-browser-extensions.mjs",
    "publish:chrome-extension": "node scripts/publish-chrome-extension.mjs",
    "security-fix": "npm audit fix",
    "security-fix:all": "npm audit fix && npm --prefix PublicLinksite audit fix && npm --prefix Mobile audit fix",
    "quality": "npm run lint && npm run test && npm run build && npm run security-check",
    "quality:all": "npm run lint && npm run test:all && npm run build && npm run security-check:all",
    "build:update": "node scripts/sync-version.mjs && npx dotenv -e .env -- npx tauri build && node scripts/generate-latest.mjs"
  },
