{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "fiip",
  "version": "9.0.4",
  "identifier": "com.darkii.fiip",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fiip",
        "width": 1180,
        "height": 760,
        "resizable": true,
        "maximized": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "label": "main",
        "devtools": false,
        "visible": true
      }
    ],
    "macOSPrivateApi": false,
    "security": {
      "csp": "default-src 'self' tauri: asset: http://asset.localhost; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob: https:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://fqouvzkovppyqocfxanl.supabase.co wss://fqouvzkovppyqocfxanl.supabase.co https://*.supabase.co wss://*.supabase.co https://keyauth.win https://openrouter.ai https://api.openrouter.ai https://fiip.fr https://portail.fiip.fr https://vinsstudio.mysellauth.com wss:;"
    }
  },
  "plugins": {
    "deep-link": {
      "schemes": [
        "fiip"
      ]
    },
    "updater": {
      "endpoints": [
        "https://github.com/darkiifr/Fiip/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3QjA3RUM2NTQ4NDRBMkMKUldRc1NvUlV4bjZ3bDQzSWJ2bHFCMmd5Q0FCUUxBVStjaGNFZVEycldDdEZDMzYzZTdvb29yYXMK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      ".portable"
    ],
    "fileAssociations": [
      {
        "ext": [
          "fiin"
        ],
        "name": "Fiip Note File",
        "description": "Fiip Note file",
        "role": "Editor"
      }
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "French",
          "English"
        ]
      }
    }
  }
}
