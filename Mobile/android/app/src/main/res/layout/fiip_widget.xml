<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fiip_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fiip_widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/fiip_widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="sans"
            android:maxLines="1"
            android:text="@string/app_name"
            android:textColor="#101828"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/fiip_widget_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/fiip_widget_chip"
            android:text="0"
            android:textColor="#6750A4"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/fiip_widget_recent_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/fiip_widget_surface"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Aucune note recente"
        android:textColor="#1D1B20"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/fiip_widget_recent_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="3"
        android:text="Creez une note dans Fiip pour remplir ce widget."
        android:textColor="#49454F"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/fiip_widget_favorites"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 favoris"
            android:textColor="#49454F"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/fiip_widget_locked"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="0 privees"
            android:textColor="#49454F"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/fiip_widget_new_note"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/fiip_widget_button"
            android:text="Nouvelle"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
