<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fiip_quick_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fiip_widget_background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/fiip_quick_widget_logo"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/fiip_widget_chip"
        android:gravity="center"
        android:text="F"
        android:textColor="#6750A4"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/fiip_quick_widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="Fiip"
        android:textColor="#1D1B20"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/fiip_quick_widget_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:text="0 notes"
        android:textColor="#49454F"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/fiip_quick_widget_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/fiip_widget_button"
        android:gravity="center"
        android:text="Nouvelle"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
