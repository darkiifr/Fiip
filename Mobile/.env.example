# Fiip Mobile Environment Configuration
# Dupliquez ce fichier en '.env' et ajoutez y vos clés.

VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

VITE_KEYAUTH_NAME=YOUR_KEYAUTH_NAME
VITE_KEYAUTH_OWNERID=YOUR_KEYAUTH_OWNERID
VITE_KEYAUTH_SECRET=YOUR_KEYAUTH_SECRET
VITE_KEYAUTH_VERSION=1.0

# Inject this from GitHub Actions secrets for production builds.
# The mobile app no longer accepts user-provided OpenRouter keys.
VITE_OPENROUTER_KEY=YOUR_OPENROUTER_KEY
